# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# Local development
MONGO_URI=mongodb://localhost:27017/todo-schedule
# Docker Compose (use this instead when running via docker-compose)
# MONGO_URI=mongodb://mongodb:27017/todo-schedule

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL of the frontend (no trailing slash)
CLIENT_URL=http://localhost:5173

# ── Google Sheets Integration ─────────────────────────────────────────────────
# The ID found in your spreadsheet URL:
#   https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Service account credentials (from Google Cloud Console → IAM → Service Accounts)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the private key exactly as shown in the JSON key file.
# Keep the quotes and include all \n escape sequences.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
